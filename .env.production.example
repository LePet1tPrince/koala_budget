# Production Environment Variables
# Copy this file to .env.production and fill in the values
# IMPORTANT: Generate different secrets for dev and prod!

# Django Settings - Production
SECRET_KEY_PROD=your-production-secret-key-here-generate-a-long-random-string
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-droplet-ip
DJANGO_SECURE_SSL_REDIRECT=True

# CSRF and session cookie security - set to True once SSL/HTTPS is configured,
# False if running over plain HTTP (e.g. before SSL certificates are set up).
# When False, the CSRF cookie can be sent over HTTP so sign-in works without HTTPS.
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SESSION_COOKIE_SECURE=True

# Trusted origins for CSRF - must include the scheme (http:// or https://).
# Add your domain (and IP if accessed directly). Separate multiple values with commas.
# Example: CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Shared Database Settings (used by both dev and prod)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password-here
REDIS_PASSWORD=your-secure-redis-password-here

# Production-specific Database
POSTGRES_DB_PROD=koala_budget_prod

# Optional: Email settings (for Django to send emails)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Optional: Sentry for error tracking
# SENTRY_DSN=your-sentry-dsn-here
# SENTRY_ENVIRONMENT=production
