# Production Environment Variables
# Copy this file to .env.production and fill in the values
# IMPORTANT: Generate different secrets for dev and prod!

# Django Settings - Production
SECRET_KEY_PROD=your-production-secret-key-here-generate-a-long-random-string
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-droplet-ip
DJANGO_SECURE_SSL_REDIRECT=True

# Shared Database Settings (used by both dev and prod)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password-here
REDIS_PASSWORD=your-secure-redis-password-here

# Production-specific Database
POSTGRES_DB_PROD=koala_budget_prod

# Optional: Email settings (for Django to send emails)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Optional: Sentry for error tracking
# SENTRY_DSN=your-sentry-dsn-here
# SENTRY_ENVIRONMENT=production
