# Development Environment Variables
# Copy this file to .env.dev and fill in the values
# IMPORTANT: Use different secrets than production!

# Django Settings - Development
SECRET_KEY_DEV=your-development-secret-key-here-different-from-prod
ALLOWED_HOSTS_DEV=localhost,127.0.0.1,dev.koalabudget.com,your-droplet-ip
DJANGO_SECURE_SSL_REDIRECT=False

# CSRF and session cookie security - set to True once HTTPS is configured for dev.
# Keep False if running over plain HTTP.
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SESSION_COOKIE_SECURE=False

# Trusted origins for CSRF - update to https:// after SSL is set up.
CSRF_TRUSTED_ORIGINS_DEV=https://dev.koalabudget.com

# Shared Database Settings (same as production)
# These should match the values in .env.production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password-here
REDIS_PASSWORD=your-secure-redis-password-here

# Development-specific Database
POSTGRES_DB_DEV=koala_budget_dev

# Optional: Email settings (can use console backend for dev)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Optional: Sentry for error tracking
# SENTRY_DSN=your-sentry-dsn-here
# SENTRY_ENVIRONMENT=development
