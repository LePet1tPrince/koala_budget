# Email configuration
# In development, emails are printed to the console (default). No extra config needed.
# In production, use Mailgun by setting the variables below:
#
#   EMAIL_BACKEND="anymail.backends.mailgun.EmailBackend"
#   DEFAULT_FROM_EMAIL="noreply@yourdomain.com"
#   SERVER_EMAIL="noreply@yourdomain.com"
#   MAILGUN_API_KEY="key-***"
#   MAILGUN_SENDER_DOMAIN="mg.yourdomain.com"
#
# Email verification on signup: "mandatory" (default), "optional", or "none"
# ACCOUNT_EMAIL_VERIFICATION="mandatory"

